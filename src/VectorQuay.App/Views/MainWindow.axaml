<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VectorQuay.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="920"
        x:Class="VectorQuay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VectorQuay"
        Icon="avares://VectorQuay.App/Assets/avalonia-logo.ico"
        MinWidth="1200"
        MinHeight="840"
        Background="#FFFFFF">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D7DBF4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#33407C"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#33407C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DFE4FB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#5F6794"/>
        </Style>
        <Style Selector="Button.segment">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#4D5686"/>
            <Setter Property="BorderBrush" Value="#DFE4FB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.segment.active">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#2B357F"/>
            <Setter Property="BorderBrush" Value="#CFD7FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*" RowDefinitions="*,Auto" Background="#FFFFFF">
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#262B5B">
            <Grid RowDefinitions="Auto,*" Margin="0">
                <StackPanel Margin="20,20,20,12" Spacing="18">
                    <Border Background="#33407C" CornerRadius="14" Padding="14,14" BorderBrush="#3E4A94" BorderThickness="1">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Border Background="White" CornerRadius="14" Padding="8" HorizontalAlignment="Center">
                                <Image Width="92"
                                       Height="92"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Stretch="Uniform"
                                       Source="avares://VectorQuay.App/Assets/Brand/vectorquay-mark-shell.png"/>
                            </Border>
                            <TextBlock Text="VectorQuay"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="16,0,16,20" Spacing="2">
                    <Button Classes="nav" Classes.active="{Binding IsHomeSection}" Command="{Binding SetSectionCommand}" CommandParameter="Home" Content="Overview"/>
                    <Button Classes="nav" Classes.active="{Binding IsPortfolioSection}" Command="{Binding SetSectionCommand}" CommandParameter="Portfolio" Content="Portfolio"/>
                    <Button Classes="nav" Classes.active="{Binding IsActivitySection}" Command="{Binding SetSectionCommand}" CommandParameter="Activity" Content="Activity"/>
                    <Button Classes="nav" Classes.active="{Binding IsPerformanceSection}" Command="{Binding SetSectionCommand}" CommandParameter="Performance" Content="Performance"/>
                    <Button Classes="nav" Classes.active="{Binding IsRiskSection}" Command="{Binding SetSectionCommand}" CommandParameter="Risk &amp; Thresholds" Content="Risk &amp; Thresholds"/>
                    <Button Classes="nav" Classes.active="{Binding IsAssetsSection}" Command="{Binding SetSectionCommand}" CommandParameter="Assets" Content="Assets"/>
                    <Button Classes="nav" Classes.active="{Binding IsPoliciesSection}" Command="{Binding SetSectionCommand}" CommandParameter="Policies" Content="Policies"/>
                    <Button Classes="nav" Classes.active="{Binding IsSourcesSection}" Command="{Binding SetSectionCommand}" CommandParameter="Sources" Content="Sources"/>
                    <Button Classes="nav" Classes.active="{Binding IsAlertsSection}" Command="{Binding SetSectionCommand}" CommandParameter="Alerts" Content="Alerts"/>
                    <Button Classes="nav" Classes.active="{Binding IsConfigurationSection}" Command="{Binding SetSectionCommand}" CommandParameter="Configuration" Content="Configuration"/>
                    <Button Classes="nav" Classes.active="{Binding IsAboutSection}" Command="{Binding SetSectionCommand}" CommandParameter="About" Content="About"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Grid.Row="0" Background="#F6F8FF">
            <ScrollViewer>
                <StackPanel Margin="24" Spacing="16">
                    <Border Background="#FFF4D6" BorderBrush="#F1D48A" BorderThickness="1" CornerRadius="12" Padding="10,12">
                        <TextBlock Foreground="#6A4D00" FontSize="13" Text="Global Alerts Area: reserved for future warnings, errors, and important operator notifications." TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel IsVisible="{Binding IsHomeSection}" Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Foreground="#5F6794" Text="{Binding AppVersion, StringFormat=Version {0}}"/>
                                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Overview"/>
                            </StackPanel>
                            <Border Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="999" Padding="10,8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Trading Inactive" FontWeight="SemiBold" Foreground="#2B357F"/>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="App Health"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewAppHealth}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="Coinbase"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewCoinbaseStatus}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="Application State"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="{Binding ShellStatus}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Portfolio Snapshot"/>
                                        <Button Grid.Column="1"
                                                Content="{Binding RefreshCoinbaseButtonText}"
                                                Command="{Binding RefreshCoinbaseDataCommand}"
                                                IsEnabled="{Binding CanRefreshCoinbase}"
                                                Background="#EEF2FF"
                                                Foreground="#2B357F"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel>
                                            <TextBlock Classes="label" Text="Total Value"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewTotalValue}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Classes="label" Text="Open Positions"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewOpenPositions}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Classes="label" Text="USD Available"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewUsdAvailable}"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Classes="label" Text="{Binding OverviewRefreshSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Top 10 Trade Assets"/>
                                    <ItemsControl ItemsSource="{Binding TopTradeAssetItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TopTradeAssetViewModel">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,0,0,8">
                                                    <Grid Width="22" Height="22">
                                                        <Image Width="22" Height="22" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                        <Border Width="22" Height="22" CornerRadius="11" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" Spacing="0">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding AssetName}"/>
                                                        <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding Priority}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Allocation Snapshot"/>
                                    <TextBlock Classes="label" Text="{Binding AllocationSummary}" TextWrapping="Wrap"/>
                                    <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                                        <Grid Width="164" Height="164" HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <Ellipse Width="164" Height="164" Fill="#F5F7FF" Stroke="#D9E0FF" StrokeThickness="1"/>
                                            <ItemsControl ItemsSource="{Binding AllocationSlices}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas Width="164" Height="164"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:AllocationSliceViewModel">
                                                        <Path Data="{Binding PathData}" Stroke="{Binding Brush}" StrokeThickness="34" Stretch="None">
                                                            <ToolTip.Tip>
                                                                <TextBlock Text="{Binding TooltipText}"/>
                                                            </ToolTip.Tip>
                                                        </Path>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Ellipse Width="76" Height="76" Fill="White" Stroke="#E4E9FF" StrokeThickness="1"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Classes="label" HorizontalAlignment="Center" Text="Total"/>
                                                <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#262B5B" Text="{Binding OverviewTotalValue}"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding AllocationSlices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AllocationSliceViewModel">
                                                    <Grid ColumnDefinitions="18,Auto,*,70,90" ColumnSpacing="10" Margin="0,0,0,8">
                                                        <Border Width="12" Height="12" CornerRadius="999" Background="{Binding Brush}" VerticalAlignment="Center"/>
                                                        <Grid Grid.Column="1" Width="20" Height="20" VerticalAlignment="Center">
                                                            <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                            <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                            </Border>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2" Spacing="0">
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding AssetName}"/>
                                                            <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding PercentText}"/>
                                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding UsdValue}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Recent Activity"/>
                                    <Grid ColumnDefinitions="120,140,80,*" ColumnSpacing="10" Margin="0,0,0,6">
                                        <TextBlock FontWeight="Bold" Text="Timestamp"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" Text="Asset"/>
                                        <TextBlock Grid.Column="2" FontWeight="Bold" Text="Action"/>
                                        <TextBlock Grid.Column="3" FontWeight="Bold" Text="Amount"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding RecentOverviewActivityItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:OverviewActivityRowViewModel">
                                                <Border BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,0,6" Background="#FBFCFF">
                                                    <Grid ColumnDefinitions="120,140,80,*" ColumnSpacing="10">
                                                        <TextBlock Text="{Binding Timestamp}"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                            <Grid Width="18" Height="18" VerticalAlignment="Center">
                                                                <Image Width="18" Height="18" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                                <Border Width="18" Height="18" CornerRadius="9" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock Text="{Binding AssetSymbol}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding Action}"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Amount}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*" RowDefinitions="Auto" ColumnSpacing="14" RowSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="System Summary"/>
                                    <TextBlock Text="{Binding ShellMessage}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsConfigurationSection}" Spacing="16">
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="#262B5B" Text="Configuration"/>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Connections"/>
                                <StackPanel Spacing="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Coinbase"/>
                                        <TextBlock Classes="label" Text="Use the downloaded CDP JSON key file." TextWrapping="Wrap"/>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBox Text="{Binding CoinbaseJsonImportPath}" PlaceholderText="/home/brad/.config/VectorQuay/cdp_api_key.json"/>
                                            <Button Grid.Column="1" Content="Browse" Click="OnBrowseCoinbaseJson"/>
                                        </Grid>
                                        <TextBlock Classes="label" Text="{Binding CoinbaseJsonKeyFilePath}" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Content="Save Coinbase"
                                                    Command="{Binding SaveCoinbaseConnectionCommand}"
                                                    Background="#262B5B"
                                                    Foreground="White"/>
                                            <Button Command="{Binding RefreshCoinbaseDataCommand}"
                                                    Content="{Binding RefreshCoinbaseButtonText}"
                                                    IsEnabled="{Binding CanRefreshCoinbase}"
                                                    Background="#EEF2FF"
                                                    Foreground="#2B357F"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Height="1"/>
                                    <StackPanel Spacing="6">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="OpenAI"/>
                                        <TextBlock Classes="label" Text="Used for future AI-assisted features." TextWrapping="Wrap"/>
                                        <TextBox Width="280" Text="{Binding OpenAiApiKeyEditor}" PlaceholderText="sk-..." />
                                        <Button Content="Save OpenAI"
                                                Command="{Binding SaveOpenAiConnectionCommand}"
                                                Background="#262B5B"
                                                Foreground="White"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Background="#FFFFFF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <TextBlock Foreground="#424A76" Text="{Binding ConnectionsActionMessage}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAssetsSection}" Spacing="16">
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#262B5B" Text="Asset Universe"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBox Width="180" PlaceholderText="Search asset" Text="{Binding AssetSearchText}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding AssetStateOptions}" SelectedItem="{Binding AssetStateFilter}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding AssetSortOptions}" SelectedItem="{Binding AssetSortOrder}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="{Binding RefreshUniverseButtonText}"
                                            Command="{Binding RefreshCoinbaseDataCommand}"
                                            IsEnabled="{Binding CanRefreshCoinbase}"
                                            Background="#EEF2FF"
                                            Foreground="#2B357F"/>
                                </Grid>
                                <Grid ColumnDefinitions="180,140,140" ColumnSpacing="10" Margin="0,4,0,0">
                                    <TextBlock FontWeight="Bold" Text="Asset"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="State"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Priority"/>
                                </Grid>
                                <ScrollViewer MaxHeight="520" HorizontalAlignment="Left" Width="430">
                                    <ItemsControl ItemsSource="{Binding AssetRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AssetRowViewModel">
                                                <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                    <Grid ColumnDefinitions="180,140,140" ColumnSpacing="10">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Grid Width="20" Height="20" VerticalAlignment="Center">
                                                                <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                                <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                                </Border>
                                                            </Grid>
                                                            <StackPanel Spacing="0">
                                                                <TextBlock Text="{Binding AssetName}" TextWrapping="Wrap"/>
                                                                <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding State}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Priority}" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Classes="label" Text="{Binding AssetCountSummary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPoliciesSection}" Spacing="16">
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#262B5B" Text="Policies"/>
                                <Grid ColumnDefinitions="*" ColumnSpacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBox Width="180" PlaceholderText="Search policy" Text="{Binding PolicySearchText}"/>
                                        <ComboBox Width="160" ItemsSource="{Binding PolicyModeOptions}" SelectedItem="{Binding PolicyModeFilter}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Classes="label" Text="Check one or more approved assets, then use the tools on the right to update those policies in bulk." TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="72,170,150,*" ColumnSpacing="10" Margin="0,0,0,8">
                                                <TextBlock FontWeight="Bold" Text="Select"/>
                                                <TextBlock Grid.Column="1" FontWeight="Bold" Text="Asset"/>
                                                <TextBlock Grid.Column="2" FontWeight="Bold" Text="Mode"/>
                                                <TextBlock Grid.Column="3" FontWeight="Bold" Text="Notes"/>
                                            </Grid>
                                            <CheckBox Content="All" IsChecked="{Binding AreAllPoliciesSelected}" HorizontalAlignment="Left"/>
                                            <ScrollViewer MaxHeight="420">
                                                <ItemsControl ItemsSource="{Binding VisiblePolicyRules}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PolicyRuleViewModel">
                                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                                <Grid ColumnDefinitions="72,170,150,*" ColumnSpacing="10">
                                                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                                        <Grid Width="20" Height="20" VerticalAlignment="Center">
                                                                            <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                                            <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                                            </Border>
                                                                        </Grid>
                                                                        <StackPanel Spacing="0">
                                                                            <TextBlock Text="{Binding AssetName}"/>
                                                                            <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Mode}"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            <TextBlock Classes="label" Text="{Binding PolicyCountSummary}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="10">
                                            <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Bulk Policy Update"/>
                                            <TextBlock Classes="label" Text="Apply the selected mode and notes to all checked policy rows." TextWrapping="Wrap"/>
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="label" Text="Trading Mode"/>
                                                <ComboBox ItemsSource="{Binding ProtectedAssetModes}" SelectedItem="{Binding SelectedPolicyModeEditor}" HorizontalAlignment="Left" Width="180"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="label" Text="Notes"/>
                                                <TextBox Text="{Binding SelectedPolicyNotesEditor}" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button Content="Apply" Command="{Binding SaveSelectedPolicyCommand}" Background="#262B5B" Foreground="White"/>
                                                <Button Content="Undo" Command="{Binding UndoSelectedPolicyChangesCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                                            </StackPanel>
                                            <Border Background="#FFFFFF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                                <TextBlock Text="{Binding SettingsActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPortfolioSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Portfolio"/>
                        <TextBlock Classes="label" Text="Detailed holdings, allocation, and exposure drilldown live here. Overview keeps only the summary layer." TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="Total Value"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioTotalValue}"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Current View"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioUnrealizedSummary}"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Cash / Stable"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioCashStableSummary}"/></StackPanel></Border>
                            <Border Grid.Column="3" Classes="card"><StackPanel><TextBlock Classes="label" Text="Largest Exposure"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioLargestExposure}"/></StackPanel></Border>
                        </Grid>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Allocation"/>
                                    <TextBlock Classes="label" Text="{Binding AllocationSummary}" TextWrapping="Wrap"/>
                                    <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                                        <Grid Width="164" Height="164" HorizontalAlignment="Center" VerticalAlignment="Top">
                                            <Ellipse Width="164" Height="164" Fill="#F5F7FF" Stroke="#D9E0FF" StrokeThickness="1"/>
                                            <ItemsControl ItemsSource="{Binding AllocationSlices}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas Width="164" Height="164"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:AllocationSliceViewModel">
                                                        <Path Data="{Binding PathData}" Stroke="{Binding Brush}" StrokeThickness="34" Stretch="None">
                                                            <ToolTip.Tip>
                                                                <TextBlock Text="{Binding TooltipText}"/>
                                                            </ToolTip.Tip>
                                                        </Path>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Ellipse Width="76" Height="76" Fill="White" Stroke="#E4E9FF" StrokeThickness="1"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Classes="label" HorizontalAlignment="Center" Text="Total"/>
                                                <TextBlock HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#262B5B" Text="{Binding PortfolioTotalValue}"/>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding AllocationSlices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AllocationSliceViewModel">
                                                    <Grid ColumnDefinitions="18,Auto,*,70,90" ColumnSpacing="10" Margin="0,0,0,8">
                                                        <Border Width="12" Height="12" CornerRadius="999" Background="{Binding Brush}" VerticalAlignment="Center"/>
                                                        <Grid Grid.Column="1" Width="20" Height="20" VerticalAlignment="Center">
                                                            <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                            <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                            </Border>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2" Spacing="0">
                                                            <TextBlock VerticalAlignment="Center" Text="{Binding AssetName}"/>
                                                            <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding PercentText}"/>
                                                        <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding UsdValue}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Portfolio Risk"/>
                                    <TextBlock Classes="label" Text="{Binding PortfolioRiskPostureSummary}" TextWrapping="Wrap"/>
                                    <Border Background="#F7F9FF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                            <Grid ColumnDefinitions="140,*">
                                                <TextBlock Classes="label" Text="Largest Position"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PortfolioLargestExposure}" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="140,*">
                                                <TextBlock Classes="label" Text="Cash / Stable Share"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PortfolioCashShareSummary}" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Grid.Row="2" ColumnDefinitions="140,*">
                                                <TextBlock Classes="label" Text="Constrained Assets"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PortfolioProtectedPolicyCount}" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <TextBlock Classes="label" Text="{Binding PortfolioProtectedAssetsSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Holdings Detail"/>
                                <Grid ColumnDefinitions="170,110,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Asset"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Quantity"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Avg Cost"/>
                                    <TextBlock Grid.Column="3" FontWeight="Bold" Text="Value"/>
                                    <TextBlock Grid.Column="4" FontWeight="Bold" Text="Allocation"/>
                                    <TextBlock Grid.Column="5" FontWeight="Bold" Text="Notes"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PortfolioHoldings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PortfolioHoldingViewModel">
                                            <Grid ColumnDefinitions="170,110,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Grid Width="20" Height="20" VerticalAlignment="Center">
                                                        <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                        <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                        </Border>
                                                    </Grid>
                                                    <StackPanel Spacing="0">
                                                        <TextBlock Text="{Binding AssetName}"/>
                                                        <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Quantity}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding AvgCost}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Value}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Allocation}"/>
                                                <TextBlock Grid.Column="5" Text="{Binding Notes}" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Selected Position Detail"/>
                                    <TextBlock Text="{Binding PortfolioSelectedPositionSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Portfolio History"/>
                                    <Border Height="150" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="12" Background="#FBFCFF">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding PortfolioHistorySummary}" Foreground="#5F6794" TextWrapping="Wrap" Margin="20"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsActivitySection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Activity"/>
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                        <StackPanel Width="170" Spacing="4">
                                            <TextBlock Classes="label" Text="Asset"/>
                                            <ComboBox ItemsSource="{Binding ActivityAssetOptions}" SelectedItem="{Binding ActivityAssetFilter}"/>
                                        </StackPanel>
                                        <StackPanel Width="150" Spacing="4">
                                            <TextBlock Classes="label" Text="Action"/>
                                            <ComboBox ItemsSource="{Binding ActivityActionOptions}" SelectedItem="{Binding ActivityActionFilter}"/>
                                        </StackPanel>
                                        <StackPanel Width="170" Spacing="4">
                                            <TextBlock Classes="label" Text="Outcome"/>
                                            <ComboBox ItemsSource="{Binding ActivityOutcomeOptions}" SelectedItem="{Binding ActivityOutcomeFilter}"/>
                                        </StackPanel>
                                </StackPanel>
                                <TextBlock Classes="label" Text="{Binding ActivityCountSummary}" TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="150,170,120,120,130,*" ColumnSpacing="10" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Timestamp"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Asset"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Action"/>
                                    <TextBlock Grid.Column="3" FontWeight="Bold" Text="Amount"/>
                                    <TextBlock Grid.Column="4" FontWeight="Bold" Text="Status"/>
                                    <TextBlock Grid.Column="5" FontWeight="Bold" Text="Detail"/>
                                </Grid>
                                <Border Background="#F7F9FF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding ShowNoActivityEntries}">
                                    <TextBlock Foreground="#5F6794" Text="No Coinbase account events matched the current filters. Adjust the filters or refresh Coinbase to reload the latest activity." TextWrapping="Wrap"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding ActivityEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActivityEntryViewModel">
                                            <Button Command="{Binding $parent[Window].DataContext.SelectActivityEntryCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch">
                                                <Border Background="#FFFFFF" CornerRadius="10" Padding="8" BorderBrush="#DFE4FB" BorderThickness="1" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="150,170,120,120,130,*" ColumnSpacing="10">
                                                        <TextBlock Text="{Binding Timestamp}" TextWrapping="Wrap"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                            <Grid Width="20" Height="20" VerticalAlignment="Center">
                                                                <Image Width="20" Height="20" Source="{Binding AssetIcon}" IsVisible="{Binding HasAssetIcon}"/>
                                                                <Border Width="20" Height="20" CornerRadius="10" Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" IsVisible="{Binding ShowAssetFallback}">
                                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#2B357F" Text="{Binding AssetMonogram}"/>
                                                                </Border>
                                                            </Grid>
                                                            <StackPanel Spacing="0">
                                                                <TextBlock Text="{Binding AssetName}" TextWrapping="Wrap"/>
                                                                <TextBlock Classes="label" Text="{Binding AssetSymbol}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding Action}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Amount}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding Outcome}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding Confidence}" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Event Details"/>
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
                                    <TextBlock Classes="label" Text="Event"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActivityDetailTitle}" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
                                    <TextBlock Classes="label" Text="Timestamp"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActivityDetailTimestamp}"/>
                                </Grid>
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
                                    <TextBlock Classes="label" Text="Amount"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActivityDetailAmount}"/>
                                </Grid>
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
                                    <TextBlock Classes="label" Text="Status"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActivityDetailStatus}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Coinbase Detail"/>
                                <TextBlock Classes="label" Text="{Binding ActivityDetailSummary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Source"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Signal"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Weight"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SelectedActivitySources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActivitySourceContributionViewModel">
                                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Source}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Signal}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Weight}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPerformanceSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Performance"/>
                        <TextBlock Classes="label" Text="This Phase 2 view summarizes current account state honestly without inventing long-term performance metrics." TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange24H}" Content="24H" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="24H"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange7D}" Content="7D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="7D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange30D}" Content="30D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="30D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange90D}" Content="90D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="90D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange1Y}" Content="1Y" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="1Y"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRangeAll}" Content="ALL" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="ALL"/>
                        </StackPanel>
                        <TextBlock Classes="label" Text="{Binding PerformanceRangeSummary}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="Current Portfolio Value"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioTotalValue}"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Cash / Stable"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding PortfolioCashStableSummary}"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Recent Activity Rows"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding ActivityEntryCountSummary}"/></StackPanel></Border>
                        </Grid>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Current Holdings Mix"/>
                                    <TextBlock Text="{Binding PerformanceTopHoldingsSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Recent Activity Mix"/>
                                    <TextBlock Text="{Binding PerformanceActivityMixSummary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Read-Only Boundary"/>
                                <TextBlock Text="{Binding PerformanceReadModelSummary}" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="{Binding PortfolioHistorySummary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsRiskSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Risk &amp; Thresholds"/>
                        <TextBlock Classes="label" Text="Choose an operating profile, then use Custom only when you need to override the recommended thresholds." TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="segment" Classes.active="{Binding IsHighRiskProfile}" Content="High Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="High Risk"/>
                            <Button Classes="segment" Classes.active="{Binding IsMediumRiskProfile}" Content="Medium Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Medium Risk"/>
                            <Button Classes="segment" Classes.active="{Binding IsLowRiskProfile}" Content="Low Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Low Risk"/>
                            <Button Classes="segment" Classes.active="{Binding IsCustomRiskProfile}" Content="Custom" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Custom"/>
                        </StackPanel>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="{Binding SelectedRiskProfile, StringFormat=Selected Profile: {0}}"/>
                                <TextBlock Classes="label" Text="{Binding RiskProfileMessage}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Operator-Safe Controls"/>
                                    <TextBlock Classes="label" Text="{Binding SelectedRiskProfile, StringFormat=Direct editing mode: {0}}" />
                                    <TextBlock Classes="label" Text="Threshold fields are editable only when Custom is selected." TextWrapping="Wrap"/>
                                    <TextBlock Classes="label" Text="Max Daily Loss"/>
                                    <TextBox Text="{Binding CustomDailyLossPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                    <TextBlock Classes="label" Text="Max Position Size"/>
                                    <TextBox Text="{Binding CustomMaxPositionPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                    <TextBlock Classes="label" Text="Max Portfolio Exposure / Turnover"/>
                                    <TextBox Text="{Binding CustomTurnoverPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Advanced Thresholds"/>
                                    <TextBlock Classes="label" Text="{Binding AdvancedThresholdsSummary}" TextWrapping="Wrap"/>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Foreground="#262B5B" Text="Spread Tolerance"/>
                                            <TextBlock Foreground="#6B7287" Text="{Binding AdvancedSpreadToleranceSummary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Foreground="#262B5B" Text="Liquidity Minimum"/>
                                            <TextBlock Foreground="#6B7287" Text="{Binding AdvancedLiquidityMinimumSummary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Foreground="#262B5B" Text="Confidence Cutoff"/>
                                            <TextBlock Foreground="#6B7287" Text="{Binding AdvancedConfidenceCutoffSummary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Button Content="Save" Command="{Binding SaveSettingsCommand}" Background="#262B5B" Foreground="White" HorizontalAlignment="Left"/>
                        <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                            <TextBlock Text="{Binding SettingsActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsSourcesSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Sources"/>
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="label" Text="Manage the local source registry used by the shell. Direct sources and watchers can be added, updated, and removed here." TextWrapping="Wrap"/>
                                <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Sources vs Watchers"/>
                                        <TextBlock Classes="label" Text="Sources are direct operational inputs like exchange or structured data feeds. Watchers are observational monitors like news, topics, or communities that surface ideas for review." TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="segment" Classes.active="{Binding IsAllSourceView}" Content="All" Command="{Binding SetSourceViewCommand}" CommandParameter="All"/>
                                        <Button Classes="segment" Classes.active="{Binding IsDirectSourceView}" Content="Direct Sources" Command="{Binding SetSourceViewCommand}" CommandParameter="Direct Sources"/>
                                        <Button Classes="segment" Classes.active="{Binding IsWatchersSourceView}" Content="Watchers" Command="{Binding SetSourceViewCommand}" CommandParameter="Watchers"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button Content="Add Source" Click="OnAddSource"/>
                                        <Button Content="Add Watcher" Click="OnAddWatcher"/>
                                        <TextBox Width="200" PlaceholderText="Search source" Text="{Binding SourceSearchText}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding SourceStateOptions}" SelectedItem="{Binding SourceStateFilter}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                                    <Border Classes="card" Background="#FFFFFF">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="label" Text="{Binding SourceCountSummary}" TextWrapping="Wrap"/>
                                            <Grid ColumnDefinitions="280,130,120,90" ColumnSpacing="10" Margin="0,0,0,6">
                                                <TextBlock FontWeight="Bold" Text="Source"/>
                                                <TextBlock Grid.Column="1" FontWeight="Bold" Text="Type"/>
                                                <TextBlock Grid.Column="2" FontWeight="Bold" Text="State"/>
                                                <TextBlock Grid.Column="3" FontWeight="Bold" Text="Weight"/>
                                            </Grid>
                                            <ScrollViewer MaxHeight="420" HorizontalAlignment="Stretch" HorizontalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding VisibleSourceEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SourceEntryViewModel">
                                                        <Button Command="{Binding $parent[Window].DataContext.SelectSourceEntryCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch">
                                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                                <Grid ColumnDefinitions="280,130,120,90" ColumnSpacing="10">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Type}" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding State}" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding Weight}"/>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Classes="card" Background="#FFFFFF">
                                        <StackPanel Spacing="10">
                                            <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Source Tools"/>
                                            <TextBlock Classes="label" Text="{Binding SourceEditorSummary}" TextWrapping="Wrap"/>
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="label" Text="Name"/>
                                                <TextBox Text="{Binding SourceNameEditor}"/>
                                                <TextBlock Classes="label" Text="Scope"/>
                                                <TextBox Text="{Binding SourceScopeEditor}"/>
                                                <TextBlock Classes="label" Text="Weight"/>
                                                <ComboBox Width="160" ItemsSource="{Binding SourceWeightOptions}" SelectedItem="{Binding SourceWeightEditor}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Apply Source" Command="{Binding RunSourceActionCommand}" CommandParameter="Apply Source" Background="#262B5B" Foreground="White" IsEnabled="{Binding HasSelectedSourceEntry}"/>
                                                <Button Content="Remove Source" Command="{Binding RunSourceActionCommand}" CommandParameter="Remove Source" Background="#EEF2FF" Foreground="#2B357F" IsEnabled="{Binding HasSelectedSourceEntry}"/>
                                                <Button Content="View History" Command="{Binding RunSourceActionCommand}" CommandParameter="View History" Background="#EEF2FF" Foreground="#2B357F" IsEnabled="{Binding HasSelectedSourceEntry}"/>
                                            </StackPanel>
                                            <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                                <TextBlock Text="{Binding SourceActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAlertsSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Alerts"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="Open Alerts"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding OpenAlertsSummary}"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Muted Rules"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding MutedRulesSummary}"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Last Delivery Test"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding LastAlertDeliveryTest}"/></StackPanel></Border>
                        </Grid>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ComboBox Width="160" ItemsSource="{Binding AlertSeverityOptions}" SelectedItem="{Binding AlertSeverityFilter}"/>
                                    <ComboBox Width="180" ItemsSource="{Binding AlertDestinationOptions}" SelectedItem="{Binding AlertDestinationFilter}"/>
                                </StackPanel>
                                <TextBlock FontWeight="Bold" Text="Recent Alerts"/>
                                <Grid ColumnDefinitions="100,130,*" ColumnSpacing="10" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Severity"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Destination"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Summary"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding AlertEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AlertEntryViewModel">
                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,6">
                                                <Grid ColumnDefinitions="100,130,*" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Severity}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Destination}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="12">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="2*,*,*" Margin="0,0,0,6">
                                        <TextBlock FontWeight="Bold" Text="Rule"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" Text="Severity"/>
                                        <TextBlock Grid.Column="2" FontWeight="Bold" Text="Destination"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding AlertRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AlertRuleViewModel">
                                                <Grid ColumnDefinitions="2*,*,*" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Rule}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Severity}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Destination}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Notification Preferences"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding InAppAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="In-App Alerts"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding EmailAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="Email:"/>
                                        <TextBox Width="220" PlaceholderText="name@example.com" Text="{Binding AlertEmailAddress}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding SmsAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="SMS:"/>
                                        <TextBox Width="180" PlaceholderText="555-555-5555" Text="{Binding AlertSmsNumber}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding QuietHoursSummary, StringFormat=Quiet Hours: {0}}"/>
                                    <TextBlock Classes="label" Text="Escalation rules and external transports remain operator-configured placeholders in Phase 1." TextWrapping="Wrap"/>
                                    <Button Content="Test Alert" Command="{Binding RunAlertActionCommand}" CommandParameter="Test Alert" Background="#262B5B" Foreground="White" HorizontalAlignment="Left"/>
                                    <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <TextBlock Text="{Binding AlertActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAboutSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="About"/>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="About This Application"/>
                                <TextBlock Text="Phase 1 local administration shell for the VectorQuay Coinbase spot trading platform." TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Author/Owner: Brad Malia" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="{Binding AppVersion, StringFormat=Version: {0} · Trading Status: Inactive}" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Documentation: Roadmap, PRD, TRD, and test plans linked here in later implementation." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="Updates"/>
                                <TextBlock Classes="label" Text="{Binding AppVersion, StringFormat=Current Version: {0} · Latest Available: Manual check required}" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}" Background="#262B5B" Foreground="White"/>
                                    <Button Content="Download Update" Command="{Binding OpenUpdateActionUrlCommand}" Background="#EEF2FF" Foreground="#2B357F" IsEnabled="{Binding CanOpenUpdateActionUrl}"/>
                                    <Button Content="View Release" Command="{Binding OpenUpdateActionUrlCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Phase 1 includes a real manual update check in the shell. Safe version checks and download/open behavior should work against a configured release source before any in-app self-update behavior is considered." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Background="#FBFCFF" BorderBrush="#E7EBFC">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="Support the Author"/>
                                <Grid ColumnDefinitions="96,*" ColumnSpacing="14">
                                    <Border Width="96" Height="96" BorderBrush="#DCE2F8" BorderThickness="1" CornerRadius="12" Background="#F8FAFF">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7A82A9" Text="QR available when configured"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Classes="label" Text="Optional owner-configurable tip information only. It remains separate from trading behavior and can be disabled or omitted in resale-oriented builds." TextWrapping="Wrap"/>
                                        <Border BorderBrush="#E3E8FB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="8,10">
                                            <TextBlock Foreground="#5B638D" Text="No support address is configured in this build."/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Copy Address" Background="#DDE4FF" Foreground="#6670A3" IsEnabled="False"/>
                                            <Button Content="Supported Assets" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#DFE4FB"
                BorderThickness="1,1,0,0"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">
                <Border Width="10"
                        Height="10"
                        CornerRadius="999"
                        Background="{Binding StatusBarIndicatorBrush}"
                        VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#424A76"
                           Text="{Binding StatusBarSummary}"/>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#5F6794"
                           Text="{Binding StatusBarDetail}"/>
                <TextBlock Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="#5F6794"
                           Text="{Binding ShellStatus, StringFormat=State: {0}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
