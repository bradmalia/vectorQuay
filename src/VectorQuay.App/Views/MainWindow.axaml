<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VectorQuay.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="920"
        x:Class="VectorQuay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VectorQuay"
        Icon="avares://VectorQuay.App/Assets/avalonia-logo.ico"
        MinWidth="1200"
        MinHeight="840"
        Background="#FFFFFF">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D7DBF4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#33407C"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#33407C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DFE4FB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#5F6794"/>
        </Style>
        <Style Selector="Button.segment">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#4D5686"/>
            <Setter Property="BorderBrush" Value="#DFE4FB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.segment.active">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#2B357F"/>
            <Setter Property="BorderBrush" Value="#CFD7FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*" Background="#FFFFFF">
        <Border Grid.Column="0" Background="#262B5B">
            <Grid RowDefinitions="Auto,*" Margin="0">
                <StackPanel Margin="20,20,20,12" Spacing="18">
                    <Border Background="#33407C" CornerRadius="14" Padding="14,14" BorderBrush="#3E4A94" BorderThickness="1">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Border Background="White" CornerRadius="14" Padding="8" HorizontalAlignment="Center">
                                <Image Width="92"
                                       Height="92"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Stretch="Uniform"
                                       Source="avares://VectorQuay.App/Assets/Brand/vectorquay-mark-shell.png"/>
                            </Border>
                            <TextBlock Text="VectorQuay"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="16,0,16,20" Spacing="2">
                    <Button Classes="nav" Classes.active="{Binding IsHomeSection}" Command="{Binding SetSectionCommand}" CommandParameter="Home" Content="Overview"/>
                    <Button Classes="nav" Classes.active="{Binding IsPortfolioSection}" Command="{Binding SetSectionCommand}" CommandParameter="Portfolio" Content="Portfolio"/>
                    <Button Classes="nav" Classes.active="{Binding IsActivitySection}" Command="{Binding SetSectionCommand}" CommandParameter="Activity" Content="Activity"/>
                    <Button Classes="nav" Classes.active="{Binding IsPerformanceSection}" Command="{Binding SetSectionCommand}" CommandParameter="Performance" Content="Performance"/>
                    <Button Classes="nav" Classes.active="{Binding IsRiskSection}" Command="{Binding SetSectionCommand}" CommandParameter="Risk &amp; Thresholds" Content="Risk &amp; Thresholds"/>
                    <Button Classes="nav" Classes.active="{Binding IsAssetsSection}" Command="{Binding SetSectionCommand}" CommandParameter="Assets" Content="Assets"/>
                    <Button Classes="nav" Classes.active="{Binding IsPoliciesSection}" Command="{Binding SetSectionCommand}" CommandParameter="Policies" Content="Policies"/>
                    <Button Classes="nav" Classes.active="{Binding IsSourcesSection}" Command="{Binding SetSectionCommand}" CommandParameter="Sources" Content="Sources"/>
                    <Button Classes="nav" Classes.active="{Binding IsAlertsSection}" Command="{Binding SetSectionCommand}" CommandParameter="Alerts" Content="Alerts"/>
                    <Button Classes="nav" Classes.active="{Binding IsConfigurationSection}" Command="{Binding SetSectionCommand}" CommandParameter="Configuration" Content="Configuration"/>
                    <Button Classes="nav" Classes.active="{Binding IsAboutSection}" Command="{Binding SetSectionCommand}" CommandParameter="About" Content="About"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F6F8FF">
            <ScrollViewer>
                <StackPanel Margin="24" Spacing="16">
                    <Border Background="#FFF4D6" BorderBrush="#F1D48A" BorderThickness="1" CornerRadius="12" Padding="10,12">
                        <TextBlock Foreground="#6A4D00" FontSize="13" Text="Global Alerts Area: reserved for future warnings, errors, and important operator notifications." TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel IsVisible="{Binding IsHomeSection}" Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Foreground="#5F6794" Text="{Binding AppVersion, StringFormat=Version {0}}"/>
                                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Overview"/>
                            </StackPanel>
                            <Border Background="#EEF2FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="999" Padding="10,8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Trading Inactive" FontWeight="SemiBold" Foreground="#2B357F"/>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="App Health"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="Ready"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="Coinbase"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="Not Connected"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" Text="Application State"/>
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#262B5B" Text="{Binding ShellStatus}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Portfolio Snapshot"/>
                                        <TextBlock Grid.Column="1" Classes="label" Text="Live account data begins in Phase 2"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*">
                                        <StackPanel>
                                            <TextBlock Classes="label" Text="Total Value"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="Connect Coinbase in Phase 2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Classes="label" Text="Open Positions"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="Unavailable in Phase 1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Classes="label" Text="USD Available"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#262B5B" Text="Unavailable in Phase 1"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Top Trade Candidates"/>
                                    <ItemsControl ItemsSource="{Binding AssetRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AssetRowViewModel">
                                                <TextBlock>
                                                    <Run Text="{Binding Asset}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding State}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding Priority}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Allocation Snapshot"/>
                                        <TextBlock Grid.Column="1" Classes="label" Text="Overview only"/>
                                    </Grid>
                                    <Border Height="160" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="12" Background="#FBFCFF">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="Compact allocation view stays here. Detailed holdings and exposure analysis live on Portfolio."
                                                   Foreground="#5F6794"
                                                   TextWrapping="Wrap"
                                                   Margin="20"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Holdings Snapshot"/>
                                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,6">
                                        <TextBlock FontWeight="Bold" Text="Asset"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" Text="Status"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,4">
                                        <TextBlock Text="ETH"/>
                                        <TextBlock Grid.Column="1" Text="Protected holding"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,4">
                                        <TextBlock Text="USD"/>
                                        <TextBlock Grid.Column="1" Text="Primary route"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <TextBlock Text="USDC"/>
                                        <TextBlock Grid.Column="1" Text="Secondary route only"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Recent Activity"/>
                                    <ItemsControl ItemsSource="{Binding ActivityItems}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="System Summary"/>
                                        <TextBlock Grid.Column="1" Classes="label" Text="Status-only shell summary"/>
                                    </Grid>
                                    <TextBlock Text="{Binding ShellMessage}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsConfigurationSection}" Spacing="16">
                        <TextBlock FontSize="24" FontWeight="Bold" Foreground="#262B5B" Text="Configuration"/>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Status"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="label" Text="Coinbase API"/>
                                        <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                            <TextBlock Foreground="#424A76" Text="{Binding CoinbaseApiKeyStatus}" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Classes="label" Text="Application State"/>
                                        <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                            <TextBlock Foreground="#424A76" Text="{Binding ShellStatus}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="label" Text="Platform"/>
                                        <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                            <TextBlock Foreground="#424A76" Text="Ubuntu / Linux"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Classes="label" Text="Valuation Currency"/>
                                        <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                            <TextBlock Foreground="#424A76" Text="{Binding CurrentValuationCurrency}"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Classes="label" Text="USD remains locked as the Phase 1 valuation currency. Coinbase credentials stay outside the UI and secret values remain redacted." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Local Non-Secret Settings"/>
                                <TextBlock Classes="label" Text="{Binding ConfigurationSummary}" TextWrapping="Wrap"/>
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="label" Text="GitHub Releases Feed"/>
                                    <TextBox Text="{Binding ReleaseFeedUrl}" PlaceholderText="https://api.github.com/repos/owner/repo/releases/latest"/>
                                </StackPanel>
                                <Border Background="#F7F9FF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <StackPanel Spacing="8">
                                        <CheckBox IsChecked="{Binding UsdcSecondaryEnabled}"/>
                                        <TextBlock Margin="28,-26,0,0"
                                                   Foreground="#424A76"
                                                   Text="Keep USDC recognized as an approved secondary routing asset for later phases."
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Save" Command="{Binding SaveSettingsCommand}" Background="#262B5B" Foreground="White"/>
                                    <Button Content="Validate" Command="{Binding ValidateSettingsCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                                    <Button Content="Reset" Command="{Binding ResetToSavedCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                                </StackPanel>
                                <Border Background="#FFF7E8" BorderBrush="#F0D79A" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <TextBlock Foreground="#7A5A12" Text="{Binding SettingsActionMessage}" TextWrapping="Wrap"/>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <TextBlock Foreground="#424A76" Text="{Binding ValidationSummary}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Coinbase Setup"/>
                                <TextBlock Classes="label" Text="Coinbase credentials are not entered in the UI in Phase 1. Add them to the local secrets file below, relaunch the app, and then check the status card above." TextWrapping="Wrap"/>
                                <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="label" Text="Secrets File Path"/>
                                        <TextBlock Foreground="#424A76" Text="{Binding SecretsPath}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFFFFF" BorderBrush="#DFE4FB" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Add These Lines"/>
                                        <TextBlock Foreground="#424A76" FontFamily="Cascadia Code, Consolas, monospace" Text="VECTORQUAY_COINBASE_API_KEY=your_key_here&#x0a;VECTORQUAY_COINBASE_API_SECRET=your_secret_here" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF7E8" BorderBrush="#F0D79A" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                    <TextBlock Foreground="#7A5A12" Text="Environment variables override the secrets file if both are present. Do not put Coinbase secrets in tracked repo files." TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAssetsSection}" Spacing="16">
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#262B5B" Text="Asset Universe"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBox Width="180" PlaceholderText="Search asset or note" Text="{Binding AssetSearchText}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding AssetStateOptions}" SelectedItem="{Binding AssetStateFilter}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding AssetSortOptions}" SelectedItem="{Binding AssetSortOrder}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Classes="label" Text="Phase 1 shell filters" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Classes="label" Text="Discovery automation begins in later phases"/>
                                    <TextBlock Grid.Column="1" Foreground="#2B357F" FontWeight="SemiBold" Text="Refresh Universe"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,140,140,*" ColumnSpacing="10" Margin="0,4,0,0">
                                    <TextBlock FontWeight="Bold" Text="Asset"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="State"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Priority"/>
                                    <TextBlock Grid.Column="3" FontWeight="Bold" Text="Notes"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding AssetRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AssetRowViewModel">
                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                <Grid ColumnDefinitions="120,140,140,*" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Asset}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding State}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Priority}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Classes="label" Text="Newly discovered assets should appear automatically in a non-tradable state until screened. Operators should also be able to trigger a manual discovery refresh." TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Screening remains manual placeholder-only in Phase 1"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPoliciesSection}" Spacing="16">
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#262B5B" Text="Policies"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBox Width="180" PlaceholderText="Search policy" Text="{Binding PolicySearchText}"/>
                                        <ComboBox Width="140" ItemsSource="{Binding PolicyAssetOptions}" SelectedItem="{Binding PolicyAssetFilter}"/>
                                        <ComboBox Width="160" ItemsSource="{Binding PolicyModeOptions}" SelectedItem="{Binding PolicyModeFilter}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Classes="label" Text="Local shell filtering" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Classes="label" Text="Select one rule to edit details, or select multiple rules for future bulk actions."/>
                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                                    <Border Classes="card">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="72,110,150,*" ColumnSpacing="10" Margin="0,0,0,8">
                                                <TextBlock FontWeight="Bold" Text="Select"/>
                                                <TextBlock Grid.Column="1" FontWeight="Bold" Text="Asset"/>
                                                <TextBlock Grid.Column="2" FontWeight="Bold" Text="Mode"/>
                                                <TextBlock Grid.Column="3" FontWeight="Bold" Text="Notes"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding VisiblePolicyRules}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:PolicyRuleViewModel">
                                                        <Button Command="{Binding $parent[Window].DataContext.SelectPolicyRuleCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch">
                                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                                <Grid ColumnDefinitions="72,110,150,*" ColumnSpacing="10">
                                                                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="False" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Asset}"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Mode}"/>
                                                                    <TextBlock Grid.Column="3" Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Classes="label" Text="Local policy edits persist when changed"/>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button Content="Add Rule" Background="#DDE4FF" Foreground="#6670A3" IsEnabled="False"/>
                                                <Button Content="Edit" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                            </StackPanel>
                                            <TextBlock Classes="label" Text="Rule creation and bulk edit actions remain disabled until later policy-management phases." TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Classes="card">
                                        <StackPanel Spacing="8">
                                            <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Selected Policy Details"/>
                                            <TextBlock Classes="label" Text="{Binding SelectedPolicyRule.Asset, StringFormat=Asset: {0}, TargetNullValue=Asset: None}"/>
                                            <TextBlock Classes="label" Text="{Binding SelectedPolicyRule.Mode, StringFormat=Mode: {0}, TargetNullValue=Mode: None}"/>
                                            <TextBlock Classes="label" Text="{Binding SelectedPolicyRule.Notes, StringFormat=Notes: {0}, TargetNullValue=Notes: None}"/>
                                            <TextBlock Classes="label" Text="Source: Operator rule"/>
                                            <TextBlock Classes="label" Text="Local operator policy detail"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Edit Rule" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                                <Button Content="Remove" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                                <Button Content="Reset Default" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                            </StackPanel>
                                            <Separator/>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="label" Text="BTC Protected Mode"/>
                                                    <ComboBox ItemsSource="{Binding ProtectedAssetModes}" SelectedItem="{Binding ProtectedBtcMode}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="6">
                                                    <TextBlock Classes="label" Text="ETH Protected Mode"/>
                                                    <ComboBox ItemsSource="{Binding ProtectedAssetModes}" SelectedItem="{Binding ProtectedEthMode}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPortfolioSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Portfolio"/>
                        <TextBlock Classes="label" Text="Detailed holdings, allocation, and exposure drilldown live here. Overview keeps only the summary layer." TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="Total Value"/><TextBlock FontSize="20" FontWeight="Bold" Text="Awaiting exchange connection"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Unrealized P/L"/><TextBlock FontSize="20" FontWeight="Bold" Text="Available after market sync"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Cash / Stable"/><TextBlock FontSize="20" FontWeight="Bold" Text="USD dominant"/></StackPanel></Border>
                            <Border Grid.Column="3" Classes="card"><StackPanel><TextBlock Classes="label" Text="Largest Exposure"/><TextBlock FontSize="20" FontWeight="Bold" Text="ETH"/></StackPanel></Border>
                        </Grid>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card"><StackPanel><TextBlock FontWeight="Bold" Text="Allocation"/><Border Height="170" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="12" Background="#FBFCFF"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Larger allocation and concentration chart becomes active after Coinbase portfolio sync" Foreground="#5F6794" TextWrapping="Wrap" Margin="20"/></Border></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Portfolio Risk"/>
                                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,6">
                                        <TextBlock Text="Largest Position"/>
                                        <TextBlock Grid.Column="1" Text="ETH"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,4">
                                        <TextBlock Text="Protected Assets"/>
                                        <TextBlock Grid.Column="1" Text="BTC, ETH"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <TextBlock Text="Turnover Profile"/>
                                        <TextBlock Grid.Column="1" Text="Medium Risk shell"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Holdings Detail"/>
                                <Grid ColumnDefinitions="120,110,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Asset"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Quantity"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Avg Cost"/>
                                    <TextBlock Grid.Column="3" FontWeight="Bold" Text="Value"/>
                                    <TextBlock Grid.Column="4" FontWeight="Bold" Text="Allocation"/>
                                    <TextBlock Grid.Column="5" FontWeight="Bold" Text="Notes"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,110,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,4">
                                    <TextBlock Text="ETH"/>
                                    <TextBlock Grid.Column="1" Text="Mocked"/>
                                    <TextBlock Grid.Column="2" Text="Pending sync"/>
                                    <TextBlock Grid.Column="3" Text="Pending sync"/>
                                    <TextBlock Grid.Column="4" Text="Protected"/>
                                    <TextBlock Grid.Column="5" Text="Existing protected holding from Phase 0 assumptions" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,110,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,4">
                                    <TextBlock Text="USD"/>
                                    <TextBlock Grid.Column="1" Text="Mocked"/>
                                    <TextBlock Grid.Column="2" Text="n/a"/>
                                    <TextBlock Grid.Column="3" Text="Pending sync"/>
                                    <TextBlock Grid.Column="4" Text="Primary route"/>
                                    <TextBlock Grid.Column="5" Text="Default valuation and routing currency for v1" TextWrapping="Wrap"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,110,120,120,120,*" ColumnSpacing="10">
                                    <TextBlock Text="USDC"/>
                                    <TextBlock Grid.Column="1" Text="Mocked"/>
                                    <TextBlock Grid.Column="2" Text="n/a"/>
                                    <TextBlock Grid.Column="3" Text="Pending sync"/>
                                    <TextBlock Grid.Column="4" Text="Secondary"/>
                                    <TextBlock Grid.Column="5" Text="Secondary routing only; kept separate from overview summary" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Selected Position Detail"/>
                                    <TextBlock Text="ETH is the mocked selected position. A future detailed portfolio page should show acquisition history, realized/unrealized performance, and related activity for the chosen asset." TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Portfolio History"/>
                                    <Border Height="150" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="12" Background="#FBFCFF">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Portfolio value curve and contribution by asset arrive once read-only Coinbase history is available." Foreground="#5F6794" TextWrapping="Wrap" Margin="20"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsActivitySection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Activity"/>
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                        <StackPanel Width="170" Spacing="4">
                                            <TextBlock Classes="label" Text="Asset"/>
                                            <ComboBox ItemsSource="{Binding ActivityAssetOptions}" SelectedItem="{Binding ActivityAssetFilter}"/>
                                        </StackPanel>
                                        <StackPanel Width="150" Spacing="4">
                                            <TextBlock Classes="label" Text="Action"/>
                                            <ComboBox ItemsSource="{Binding ActivityActionOptions}" SelectedItem="{Binding ActivityActionFilter}"/>
                                        </StackPanel>
                                        <StackPanel Width="170" Spacing="4">
                                            <TextBlock Classes="label" Text="Outcome"/>
                                            <ComboBox ItemsSource="{Binding ActivityOutcomeOptions}" SelectedItem="{Binding ActivityOutcomeFilter}"/>
                                        </StackPanel>
                                </StackPanel>
                                <Grid ColumnDefinitions="150,150,120,120,120,*" ColumnSpacing="10" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Timestamp"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Asset / Pair"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Action"/>
                                    <TextBlock Grid.Column="3" FontWeight="Bold" Text="Amount"/>
                                    <TextBlock Grid.Column="4" FontWeight="Bold" Text="Outcome"/>
                                    <TextBlock Grid.Column="5" FontWeight="Bold" Text="Confidence"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding ActivityEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActivityEntryViewModel">
                                            <Button Command="{Binding $parent[Window].DataContext.SelectActivityEntryCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch">
                                                <Border Background="#FFFFFF" CornerRadius="10" Padding="8" BorderBrush="#DFE4FB" BorderThickness="1" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="150,150,120,120,120,*" ColumnSpacing="10">
                                                        <TextBlock Text="{Binding Timestamp}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding AssetPair}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Action}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Amount}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding Outcome}" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding Confidence}" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <TextBlock Classes="label" Text="{Binding ActivitySelectionMessage}" TextWrapping="Wrap"/>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Decision Details"/>
                                <TextBlock Text="{Binding SelectedActivityDecisionSummary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Text="Policy and Risk Checks"/>
                                <TextBlock Classes="label" Text="{Binding SelectedActivityPolicyRiskSummary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,6">
                                    <TextBlock FontWeight="Bold" Text="Source"/>
                                    <TextBlock Grid.Column="1" FontWeight="Bold" Text="Signal"/>
                                    <TextBlock Grid.Column="2" FontWeight="Bold" Text="Weight"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SelectedActivitySources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActivitySourceContributionViewModel">
                                            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Source}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Signal}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Weight}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsPerformanceSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Performance"/>
                        <TextBlock Classes="label" Text="Performance history begins after strategy and portfolio data are available"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange24H}" Content="24H" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="24H"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange7D}" Content="7D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="7D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange30D}" Content="30D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="30D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange90D}" Content="90D" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="90D"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRange1Y}" Content="1Y" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="1Y"/>
                            <Button Classes="segment" Classes.active="{Binding IsPerformanceRangeAll}" Content="ALL" Command="{Binding SetPerformanceRangeCommand}" CommandParameter="ALL"/>
                        </StackPanel>
                        <TextBlock Classes="label" Text="{Binding PerformanceRangeSummary}" TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="PnL"/><TextBlock FontSize="20" FontWeight="Bold" Text="Awaiting performance history"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Win Rate"/><TextBlock FontSize="20" FontWeight="Bold" Text="Awaiting performance history"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Drawdown"/><TextBlock FontSize="20" FontWeight="Bold" Text="Awaiting performance history"/></StackPanel></Border>
                        </Grid>
                        <Border Classes="card" Height="180"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Future KPI / performance chart area" Foreground="#5F6794"/></Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsRiskSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Risk &amp; Thresholds"/>
                        <TextBlock Classes="label" Text="Preset risk shell only until later-phase live controls are connected"/>
                        <WrapPanel>
                            <Button Content="High Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="High Risk"/>
                            <Button Content="Medium Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Medium Risk"/>
                            <Button Content="Low Risk" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Low Risk"/>
                            <Button Content="Custom" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Custom"/>
                        </WrapPanel>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="{Binding SelectedRiskProfile, StringFormat=Selected Profile: {0}}"/>
                                <TextBlock Classes="label" Text="{Binding RiskProfileMessage}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Operator-Safe Controls"/>
                                    <TextBlock Classes="label" Text="{Binding SelectedRiskProfile, StringFormat=Direct editing mode: {0}}" />
                                    <TextBlock Classes="label" Text="Threshold fields are editable only when Custom is selected." TextWrapping="Wrap"/>
                                    <TextBlock Classes="label" Text="Max Daily Loss"/>
                                    <TextBox Text="{Binding CustomDailyLossPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                    <TextBlock Classes="label" Text="Max Position Size"/>
                                    <TextBox Text="{Binding CustomMaxPositionPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                    <TextBlock Classes="label" Text="Max Portfolio Exposure / Turnover"/>
                                    <TextBox Text="{Binding CustomTurnoverPct}" IsEnabled="{Binding CanEditRiskThresholds}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="Advanced Thresholds"/>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12"><TextBlock Foreground="#6B7287" Text="Spread Tolerance · Read-only until strategy engine is active"/></Border>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12"><TextBlock Foreground="#6B7287" Text="Liquidity Minimum · Read-only until strategy engine is active"/></Border>
                                    <Border Background="#EEF1F7" BorderBrush="#D7DBE8" BorderThickness="1" CornerRadius="10" Padding="10,12"><TextBlock Foreground="#6B7287" Text="Confidence Cutoff · Read-only until strategy engine is active"/></Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Save" Command="{Binding SaveSettingsCommand}" Background="#262B5B" Foreground="White"/>
                            <Button Content="Switch to Custom" Command="{Binding ApplyRiskProfileCommand}" CommandParameter="Custom" Background="#EEF2FF" Foreground="#2B357F"/>
                            <Button Content="Reset to Default" Command="{Binding ResetRiskDefaultsCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                        </StackPanel>
                        <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                            <TextBlock Text="{Binding SettingsActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsSourcesSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Sources"/>
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="label" Text="Use this page as a simple source registry. Select one source to inspect its current shell detail." TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="segment" Classes.active="{Binding IsAllSourceView}" Content="All" Command="{Binding SetSourceViewCommand}" CommandParameter="All"/>
                                        <Button Classes="segment" Classes.active="{Binding IsDirectSourceView}" Content="Direct Sources" Command="{Binding SetSourceViewCommand}" CommandParameter="Direct Sources"/>
                                        <Button Classes="segment" Classes.active="{Binding IsWatchersSourceView}" Content="Watchers" Command="{Binding SetSourceViewCommand}" CommandParameter="Watchers"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBox Width="200" PlaceholderText="Search source" Text="{Binding SourceSearchText}"/>
                                        <ComboBox Width="150" ItemsSource="{Binding SourceStateOptions}" SelectedItem="{Binding SourceStateFilter}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="14">
                                    <Border Classes="card" Background="#FFFFFF">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="280,130,120,90" ColumnSpacing="10" Margin="0,0,0,6">
                                                <TextBlock FontWeight="Bold" Text="Source"/>
                                                <TextBlock Grid.Column="1" FontWeight="Bold" Text="Type"/>
                                                <TextBlock Grid.Column="2" FontWeight="Bold" Text="State"/>
                                                <TextBlock Grid.Column="3" FontWeight="Bold" Text="Weight"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding VisibleSourceEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SourceEntryViewModel">
                                                        <Button Command="{Binding $parent[Window].DataContext.SelectSourceEntryCommand}" CommandParameter="{Binding .}" Background="Transparent" BorderThickness="0" Padding="0" HorizontalContentAlignment="Stretch">
                                                            <Border BorderBrush="#DFE4FB" BorderThickness="0,0,0,1" Padding="0,8">
                                                                <Grid ColumnDefinitions="280,130,120,90" ColumnSpacing="10">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Type}" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding State}" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="3" Text="Default"/>
                                                                </Grid>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Classes="card" Background="#FFFFFF">
                                        <StackPanel Spacing="10">
                                            <TextBlock FontWeight="Bold" Foreground="#262B5B" Text="{Binding SelectedSourceEntry.Name, StringFormat=Selected Source: {0}, TargetNullValue=Selected Source: None}"/>
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="label" Text="{Binding SelectedSourceEntry.Type, StringFormat=Type: {0}, TargetNullValue=Type: Not selected}"/>
                                                <TextBlock Classes="label" Text="{Binding SelectedSourceEntry.State, StringFormat=State: {0}, TargetNullValue=State: Not selected}"/>
                                                <TextBlock Classes="label" Text="{Binding SelectedSourceReliability}"/>
                                                <TextBlock Classes="label" Text="{Binding SelectedSourceEntry.Scope, TargetNullValue=No scope available}" TextWrapping="Wrap"/>
                                                <TextBlock Classes="label" Text="{Binding SelectedSourceContributionSummary}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Edit Weight" Command="{Binding RunSourceActionCommand}" CommandParameter="Edit Weight" Background="#262B5B" Foreground="White" IsEnabled="{Binding HasSelectedSourceEntry}"/>
                                                <Button Content="View History" Command="{Binding RunSourceActionCommand}" CommandParameter="View History" Background="#EEF2FF" Foreground="#2B357F" IsEnabled="{Binding HasSelectedSourceEntry}"/>
                                            </StackPanel>
                                            <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                                <TextBlock Text="{Binding SourceActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAlertsSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="Alerts"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Classes="card"><StackPanel><TextBlock Classes="label" Text="Open Alerts"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding OpenAlertsSummary}"/></StackPanel></Border>
                            <Border Grid.Column="1" Classes="card"><StackPanel><TextBlock Classes="label" Text="Muted Rules"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding MutedRulesSummary}"/></StackPanel></Border>
                            <Border Grid.Column="2" Classes="card"><StackPanel><TextBlock Classes="label" Text="Last Delivery Test"/><TextBlock FontSize="20" FontWeight="Bold" Text="{Binding LastAlertDeliveryTest}"/></StackPanel></Border>
                        </Grid>
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ComboBox Width="160" ItemsSource="{Binding AlertSeverityOptions}" SelectedItem="{Binding AlertSeverityFilter}"/>
                                    <ComboBox Width="180" ItemsSource="{Binding AlertDestinationOptions}" SelectedItem="{Binding AlertDestinationFilter}"/>
                                </StackPanel>
                                <TextBlock FontWeight="Bold" Text="Recent Alerts"/>
                                <ItemsControl ItemsSource="{Binding AlertEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AlertEntryViewModel">
                                            <TextBlock>
                                                <Run Text="{Binding Severity}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Destination}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Summary}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="12">
                            <Border Classes="card">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="2*,*,*" Margin="0,0,0,6">
                                        <TextBlock FontWeight="Bold" Text="Rule"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" Text="Severity"/>
                                        <TextBlock Grid.Column="2" FontWeight="Bold" Text="Destination"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding AlertRules}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AlertRuleViewModel">
                                                <Grid ColumnDefinitions="2*,*,*" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Rule}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Severity}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Destination}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="card">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="Bold" Text="Notification Preferences"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding InAppAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="In-App Alerts"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding EmailAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="Email:"/>
                                        <TextBox Width="220" PlaceholderText="name@example.com" Text="{Binding AlertEmailAddress}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <CheckBox IsChecked="{Binding SmsAlertsEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock VerticalAlignment="Center" Text="SMS:"/>
                                        <TextBox Width="180" PlaceholderText="555-555-5555" Text="{Binding AlertSmsNumber}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding QuietHoursSummary, StringFormat=Quiet Hours: {0}}"/>
                                    <TextBlock Classes="label" Text="Escalation rules and external transports remain operator-configured placeholders in Phase 1." TextWrapping="Wrap"/>
                                    <Button Content="Test Alert" Command="{Binding RunAlertActionCommand}" CommandParameter="Test Alert" Background="#262B5B" Foreground="White" HorizontalAlignment="Left"/>
                                    <Border Background="#F7F9FF" BorderBrush="#CFD7FF" BorderThickness="1" CornerRadius="10" Padding="10,12">
                                        <TextBlock Text="{Binding AlertActionMessage}" TextWrapping="Wrap" Foreground="#424A76"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAboutSection}" Spacing="16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#262B5B" Text="About"/>
                        <Border Classes="card" Background="#F7F9FF">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="About This Application"/>
                                <TextBlock Text="Phase 1 local administration shell for the VectorQuay Coinbase spot trading platform." TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Author/Owner: Brad Malia" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="{Binding AppVersion, StringFormat=Version: {0} · Trading Status: Inactive}" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Documentation: Roadmap, PRD, TRD, and test plans linked here in later implementation." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="Updates"/>
                                <TextBlock Classes="label" Text="{Binding AppVersion, StringFormat=Current Version: {0} · Latest Available: Manual check required}" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}" Background="#262B5B" Foreground="White"/>
                                    <Button Content="Download Update" Command="{Binding OpenUpdateActionUrlCommand}" Background="#EEF2FF" Foreground="#2B357F" IsEnabled="{Binding CanOpenUpdateActionUrl}"/>
                                    <Button Content="View Release" Command="{Binding OpenUpdateActionUrlCommand}" Background="#EEF2FF" Foreground="#2B357F"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap"/>
                                <TextBlock Classes="label" Text="Phase 1 includes a real manual update check in the shell. Safe version checks and download/open behavior should work against a configured release source before any in-app self-update behavior is considered." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Background="#FBFCFF" BorderBrush="#E7EBFC">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="Bold" Text="Support the Author"/>
                                <Grid ColumnDefinitions="96,*" ColumnSpacing="14">
                                    <Border Width="96" Height="96" BorderBrush="#DCE2F8" BorderThickness="1" CornerRadius="12" Background="#F8FAFF">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7A82A9" Text="QR available when configured"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Classes="label" Text="Optional owner-configurable tip information only. It remains separate from trading behavior and can be disabled or omitted in resale-oriented builds." TextWrapping="Wrap"/>
                                        <Border BorderBrush="#E3E8FB" BorderThickness="1" CornerRadius="10" Background="#FFFFFF" Padding="8,10">
                                            <TextBlock Foreground="#5B638D" Text="No support address is configured in this build."/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Content="Copy Address" Background="#DDE4FF" Foreground="#6670A3" IsEnabled="False"/>
                                            <Button Content="Supported Assets" Background="#EEF2FF" Foreground="#6670A3" IsEnabled="False"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
